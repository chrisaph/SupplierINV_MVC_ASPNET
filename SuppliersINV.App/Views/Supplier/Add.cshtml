@model Supplier

<form asp-controller="Supplier" asp-action="Add" method="post">

    <br /><br />



    <label>Company Name</label>
<input type="text" asp-for="CompanyName" asp-placeholder="Company Name" class="form-control" />

    <br />

    <label asp-for="Address"></label>
    <input type="text" asp-for="Address" class="form-control" />
    <br />

    <label asp-for="Representative"></label>
    <input type="text" asp-for="Representative" class="form-control" />
    <br />

    <label asp-for="ContactNo"></label>
    <input type="text" asp-for="ContactNo" class="form-control" />
    <br />

    

    
    <a asp-controller="Supplier" asp-action="Index" class="btn btn-success">
        Back
        <i class="fas fa-caret-square-left"></i>

    </a>

    <button type="submit" class="btn btn-success">Add Supplier
        <i class="fas fa-plus"></i>

    </button>


</form>