@model List<ProductVM>
<html>
<head>
    <style>
        .larger-text {
            font-size: 5em;
            font-family: "Courier New", monospace;
        }
    </style>
</head>
<body>
    <h1 class="larger-text">Products</h1>
</body>
</html>

<a asp-controller="Product" asp-action="Add" class="btn btn-success" style="font-family: 'Roboto', sans-serif; font-size: 18px;">
    Add New Product
    <i class="fas fa-plus"></i>

</a>

<br />
<br />

@if (Model.Count() < 1)
{
    <div class="alert alert-info">
        No Product Records Found.
    </div>
}
else
{
    <table id="ProductTable" class="table table-striped table-hover">
        <thead>
            <tr>
                <th>I.D.</th>
                <th>Name</th>
                <th>Description</th>
                <th>Qty</th>
                <th>Unit</th>
                <th>Date Added</th>
                <th>Date Modified</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductID</td>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Qty</td>
                    <td>@item.Unit</td>
                    <td>@item.DateAdded</td>
                    <td>@item.DateModified</td>
                    <td>
                        <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.ProductID" class="btn btn-info btn-sm">
                            Edit
                            <i class="fas fa-edit"></i>

                        </a>
                        @*<form asp-controller="Supplier" asp-action="Delete" method="post" style="display: grid;">
                <input type="hidden" name="Id" value="@item.SupplierID">
                <input type="submit" class="btn btn-danger btn-sm" value="Delete">
                </form>*@
                        <button class="btn btn-danger btn-sm deleteBtn" data-id="@item.ProductID">
                            Delete
                            <i class="fas fa-trash"></i>

                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<form id="DeleteForm" asp-controller="Product" asp-action="Delete" method="post">
    <input type="hidden" id="HiddenProductID" name="ProductID" value="" />

</form>

@section Scripts
    {
    <script>
        $(document).ready(function () {
            $('#ProductTable').DataTable();
        });
        $('.deleteBtn').click(function (e) {
            swal({
                title: "Are you sure?",
                text: "Are you sure you want to delete this?",
                icon: "warning",
                buttons: true,
                dangerMode: true
            }).then((confirm) => {
                if (confirm) {
                    var btn = $(this);
                    var id = btn.data("id");
                    $("#HiddenProductID").val(id);
                    $("#DeleteForm").submit();
                }
            });
        });
    </script>

}