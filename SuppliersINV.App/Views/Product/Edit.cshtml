@model ProductVM

<h3>Edit Product</h3>

<form asp-controller="Product" asp-action="Edit" method="post">
    <input type="hidden" asp-for="ProductID" />
    <label asp-for="Name"></label>
    <input type="text" asp-for="Name" class="form-control" />
    <br />

    <label asp-for="Description"></label>
    <input type="text" asp-for="Description" class="form-control" />
    <br />

    <label asp-for="Qty"></label>
    <input type="text" asp-for="Qty" class="form-control" />
    <br />

    <label asp-for="Unit"></label>
    <input type="text" asp-for="Unit" class="form-control" />
    <br />

    <a asp-controller="Product" asp-action="Index" class="btn btn-success">
        Back <i class="fas fa-caret-square-left"></i>

    </a>

    <input type="submit" class="btn btn-success" value="Save Changes">

</form>